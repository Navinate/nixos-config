# Catppuccin Mocha palette — single source of truth for colors.
# Swap this file (e.g. for tokyo-night.nix, gruvbox.nix) to retheme everything
# that imports from here.
#
# Hex values WITHOUT the leading "#" so they're easy to use inline:
#   "#${colors.base}"  →  "#1e1e2e"
#   "rgb(${colors.mauve})" → "rgb(cba6f7)"
{
  base      = "1e1e2e";
  mantle    = "181825";
  crust     = "11111b";
  surface0  = "313244";
  surface1  = "45475a";
  surface2  = "585b70";
  overlay0  = "6c7086";
  overlay1  = "7f849c";
  text      = "cdd6f4";
  subtext0  = "a6adc8";
  subtext1  = "bac2de";
  rosewater = "f5e0dc";
  flamingo  = "f2cdcd";
  pink      = "f5c2e7";
  mauve     = "cba6f7";
  red       = "f38ba8";
  maroon    = "eba0ac";
  peach     = "fab387";
  yellow    = "f9e2af";
  green     = "a6e3a1";
  teal      = "94e2d5";
  sky       = "89dceb";
  sapphire  = "74c7ec";
  blue      = "89b4fa";
  lavender  = "b4befe";
